{
  "expo": {
    "name": "Campedèl-Hof",
    "slug": "campedel-hof",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F7F4F0",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo-white.png",
      "resizeMode": "contain",
      "backgroundColor": "#83A83D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.campedelhof.menu"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#F7F4F0"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.campedelhof.menu"
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      "expo-localization"
    ]
  }
}
